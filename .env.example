# ─────────────────────────────────────────────────────────────────────────────
# Required secrets — must be set before running the agent
# ─────────────────────────────────────────────────────────────────────────────

# LiveKit Cloud credentials  (https://cloud.livekit.io → Settings → Keys)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# OpenAI API key  (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# Optional overrides (all have sensible defaults in config/dev.yaml)
# ─────────────────────────────────────────────────────────────────────────────

# Environment: "dev" or "prod" — selects config/dev.yaml or config/prod.yaml
# VOICE_AGENT_ENV=dev

# Override log level at runtime without editing YAML
# LOG_LEVEL=DEBUG
